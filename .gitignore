# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# secrets
/secrets/

# drizzle migrations: track SQL + journal/snapshots so they apply to all envs
# (the previous /drizzle/ blanket-ignore contradicted the already-tracked
#  0000-0003 migrations and left new ones invisible to git status)

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel

# Claude Code internal
.claude/

# Playwright + vitest reports
/playwright-report/
/test-results/
