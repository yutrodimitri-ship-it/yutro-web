# Normalize line endings to LF in the repo, regardless of OS.
# Each dev's working tree still uses their native EOL via core.autocrlf.
* text=auto eol=lf

# Source / config: always LF (consistent diffs across mac/linux/windows)
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.mjs       text eol=lf
*.cjs       text eol=lf
*.json      text eol=lf
*.jsonc     text eol=lf
*.md        text eol=lf
*.mdx       text eol=lf
*.css       text eol=lf
*.scss      text eol=lf
*.html      text eol=lf
*.svg       text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.toml      text eol=lf
*.sql       text eol=lf
*.env*      text eol=lf
*.sh        text eol=lf

# Lockfiles: leave as-is but tracked, no merge attempts
package-lock.json -diff
pnpm-lock.yaml    -diff
yarn.lock         -diff

# Binary assets — never normalize
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.webp      binary
*.avif      binary
*.ico       binary
*.pdf       binary
*.zip       binary
*.gz        binary
*.tgz       binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.otf       binary
*.mp4       binary
*.mp3       binary
*.wav       binary
