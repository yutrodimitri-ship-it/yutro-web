# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Database (PostgreSQL)
DATABASE_URL=postgresql://yutro:yutro_dev_2024@localhost:5432/yutro_dev

# Sanity CMS
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_READ_TOKEN=
SANITY_REVALIDATE_SECRET=change-me-in-production

# Security
CSRF_SECRET=change-me-in-production-use-32-bytes

# Rate limiting (memory | redis)
RATE_LIMIT_STORE=memory
# REDIS_URL=redis://localhost:6379

# Contact
CONTACT_EMAIL_TO=contacto@yutro.cl
# RESEND_API_KEY=

# YUTRO Studio — AI APIs
GEMINI_API_KEY=
COMFYCLOUD_API_KEY=

# Yutro Studio Talent — Fase 2
# false = lee desde mock-data.ts (Fase 1, default)
# true  = lee desde Postgres (requiere correr `npm run seed:talent` primero)
USE_DB_TALENT=false

# Yutro Studio Talent — Email (Resend, Sprint 6)
# Configurar dominio yutro.cl verificado (DKIM + SPF) antes de usar.
RESEND_API_KEY=re_xxx
EMAIL_FROM_NAME="Yutro Estudio"
EMAIL_FROM_ADDRESS=noreply@yutro.cl
EMAIL_TO=contacto@yutro.cl
EMAIL_CC=milivoy@yutro.cl

# Yutro Studio Talent — Cloudflare R2 (Sprint 8)
# Bucket privado, NO public access. Las imagenes se sirven solo via API
# con auth + ownership + watermark dinamico.
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=https://xxxxxxxxxxxx.r2.cloudflarestorage.com
R2_BUCKET=yutro-talent

# Yutro Studio Talent — Sentry observabilidad (Sprint 9)
# Si vacios, Sentry queda no-op (dev/staging sin reporting).
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Playwright tests (Sprint 9)
# Configurar antes de correr `npm run test:e2e`.
PLAYWRIGHT_CLIENT_EMAIL=test@bbdo.cl
PLAYWRIGHT_CLIENT_PASSWORD=
