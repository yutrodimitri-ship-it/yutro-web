            }</script></p></div><div class="footercolumn"><h5>Pages</h5><ul><li><a class="faq-link" href="#faq">FAQ</a></li><li><a href="/legal" target="_blank">Terms of Service</a></li><li><a href="/legal#privacy" target="_blank">Privacy Policy</a></li><li><a href="/legal#cookies" target="_blank">Cookies Policy</a></li></ul></div><div class="footercolumn"><h5 class="footer-tutorials-title">Tutorials & Social</h5><h5 class="footer-social-title" style="display:none;">Social</h5><ul><li class="footer-tutorials-link"><a href="https://twitter.com/javilopen/status/1734945521121239112" target="_blank">Tutorials</a></li><li><a href="https://twitter.com/magnific_ai" target="_blank">Twitter</a></li><li><a href="https://www.instagram.com/magnific_ai" target="_blank">Instagram</a></li><li><a href="https://www.tiktok.com/@magnific.ai" target="_blank">TikTok</a></li></ul></div><div class="footercolumn"><h5>Other sites</h5><ul><li class="footer-freepik-link"><a href="https://www.freepik.com/" target="_blank">Freepik</a></li><li class="footer-magnific-com-link" style="display:none;"></li></ul></div></div><script>const buttonTexts = [
            'Let Magnific blow your mind',
            'Prepare to be amazed by Magnific',
            'Let Magnific dazzle you',
            'Experience the magic of Magnific'
        ];

        const randomButtonText = buttonTexts[Math.floor(Math.random() * buttonTexts.length)];
        document.querySelector('.main-btn').textContent = randomButtonText;

        PowerGlitch.glitch('#glitch-logo', {
            playMode: 'always',
            createContainers: true,
            hideOverflow: false,
            timing: {
                duration: 1500,
                iterations: Infinity,
                easing: 'ease-out'
            },
            glitchTimeSpan: {
                start: 0.05,
                end: 0.5
            },
            shake: {
                velocity: 15,
                amplitudeX: 0.1,
                amplitudeY: 0.1
            },
            slice: {
                count: 5,
                velocity: 10,
                minHeight: 0.1,
                maxHeight: 0.2,
                hueRotate: true
            }
        });</script></body></html>